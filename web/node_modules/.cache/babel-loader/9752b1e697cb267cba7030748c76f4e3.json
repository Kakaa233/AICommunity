\">\r\n      <div class=\"banner\">登录账号</div>\r\n      <div class=\"main\">\r\n        <div class=\"phone\">\r\n          <div class=\"sjh\">\r\n            <el-form\r\n              :model=\"loginInfo\"\r\n              status-icon\r\n              :rules=\"rules\"\r\n              ref=\"ruleForm\"\r\n              label-width=\"100px\"\r\n              class=\"demo-ruleForm\"\r\n            >\r\n              <el-form-item label=\"手机号\" prop=\"phoneNumber\">\r\n                <el-input\r\n                  v-model=\"loginInfo.phoneNumber\"\r\n                  autocomplete=\"off\"\r\n                  placeholder=\"请输入手机号\"\r\n                ></el-input>\r\n              </el-form-item>\r\n              <el-form-item label=\"验证码\" prop=\"checkPass\">\r\n                <el-input\r\n                  v-model=\"loginInfo.checkPass\"\r\n                  autocomplete=\"off\"\r\n                  placeholder=\"请输入验证码\"\r\n                ></el-input>\r\n              </el-form-item>\r\n              <el-form-item>\r\n                <el-button\r\n                  type=\"primary\"\r\n                  @click=\"submitForm('ruleForm')\"\r\n                  class=\"reg\"\r\n                  >登录</el-button\r\n                >\r\n              </el-form-item>\r\n              <div class=\"images\">\r\n                <a href=\"http://localhost:8081/oauth/login\">\r\n                  <img src=\"@/assets/1.png\" alt=\"\" href=\"\">\r\n                </a>\r\n                <a href=\"http://localhost:8081/oauth/qq\">\r\n                  <img src=\"@/assets/2.png\" alt=\"\" href=\"\">\r\n                </a>\r\n                \r\n              </div>\r\n              \r\n              <el-button type=\"primary\" class=\"btn\" @click=\"getCheckPass()\"\r\n                >获取验证码</el-button\r\n              >\r\n            </el-form>\r\n          </div>\r\n          <div\r\n            class=\"txt\"\r\n            style=\"display: flex; justify-content: space-between\"\