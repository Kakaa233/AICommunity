 80);\r\n      }\r\n      .huifu {\r\n        width: 80px;\r\n        position: absolute;\r\n        right: 170px;\r\n        top: 60px;\r\n        font-size: 14px;\r\n        // border-right: 2px solid rgb(126, 125, 125);\r\n        color: rgb(82, 80, 80);\r\n      }\r\n      .zan {\r\n        width: 80px;\r\n        // border-right: 2px solid rgb(126, 125, 125);\r\n        position: absolute;\r\n        right: 90px;\r\n        top: 60px;\r\n        font-size: 14px;\r\n        color: rgb(82, 80, 80);\r\n      }\r\n      .liulan {\r\n        position: absolute;\r\n        right: 25px;\r\n        top: 60px;\r\n        font-size: 14px;\r\n        color: rgb(82, 80, 80);\r\n      }\r\n    }\r\n  }\r\n}\r\n::v-deep .el-button {\r\n  display: inline-block;\r\n  line-height: 1;\r\n  white-space: nowrap;\r\n  cursor: pointer;\r\n  background: #fff;\r\n  border: 1px solid #dcdfe6;\r\n  color: #606266;\r\n  -webkit-appearance: none;\r\n  text-align: center;\r\n  box-sizing: border-box;\r\n  outline: 0;\r\n  margin: 0;\r\n  transition: 0.1s;\r\n  font-weight: 500;\r\n  padding: 5px 8px;\r\n  font-size: 14px;\r\n  border-radius: 4px;\r\n  color: #87baf1;\r\n}\r\n</style>"],"mappings":";;;AAmDA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,SAAA,EAAAC,OAAA;MACAC,EAAA;MACAC,OAAA;MACAC,QAAA;QACA;QACA;QACA;QACA;QACA;QACA;QACA;QACA;QACA;QACA;MAAA,CACA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,OAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAD,YAAA;MACA,IAAAE,KAAA;MACA,IAAAC,GAAA;MACA;;MAEAD,KAAA,CAAAE,MAAA,CACAC,GAAA,CAAAF,GAAA,EACAG,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAC,MAAA;UAEAC,OAAA,CAAAC,GAAA,SAAAH,GAAA,CAAAhB,IAAA;UACA,IAAAoB,IAAA,GAAAJ,GAAA,CAAAhB,IAAA,CAAAA,IAAA;UACA,IAAAqB,IAAA;UACAD,IAAA,CAAAE,OAAA,CAAAC,IAAA;YACAF,IAAA,CAAAG,IAAA,CAAAD,IAAA,CAAAE,MAAA;UACA;UACAd,KAAA,CAAAL,UAAA,GAAAe,IAAA;QACA;MACA,GACAK,KAAA,CAAAC,GAAA;QACAT,OAAA,CAAAC,GAAA,CAAAQ,GAAA;MACA;IACA;IACAC,QAAAH,MAAA;MACA,KAAArB,OAAA,SAAAA,OAAA;MACA;MACA,IAAAO,KAAA;MACA,IAAAC,GAAA;MACA;;MAEAD,KAAA,CAAAE,MAAA,CACAC,GAAA,CAAAF,GAAA