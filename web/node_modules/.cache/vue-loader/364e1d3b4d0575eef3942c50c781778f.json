     autocomplete=\"off\"\n                  placeholder=\"请输入账号名\"\n                ></el-input>\n              </el-form-item>\n              <el-form-item label=\"密码\" prop=\"passWord\">\n                <el-input\n                  type=\"password\"\n                  v-model=\"loginInfo.passWord\"\n                  autocomplete=\"off\"\n                  placeholder=\"请输入8-20位密码\"\n                ></el-input>\n              </el-form-item>\n              <el-form-item>\n                <el-button\n                  type=\"primary\"\n                  @click=\"submitForm('ruleForm')\"\n                  class=\"reg\"\n                  >登录</el-button\n                >\n              </el-form-item>\n            </el-form>\n          </div>\n          <div\n            class=\"txt\"\n            style=\"display: flex; justify-content: space-between\"\n          >\n            <p style=\"margin-left: 95px; cursor: pointer\" @click=\"goIndex()\">\n              <i class=\"el-icon-back\"></i> 返回\n            </p>\n            <p style=\"cursor: pointer\" @click=\"goRegister()\">\n              去注册<i class=\"el-icon-right\"></i>\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Login\",\n  components: {},\n  data() {\n    return {\n      loginInfo: {\n        userId: \"\",\n        passWord: \"\",\n      },\n      rules: {\n        userId: [\n          { required: true, message: \"请输入账号名\", trigger: \"blur\" }\n        ],\n        passWord: [\n          { required: true, message: \"请输入密码\", trigger: \"blur\" },\n        ],\n      },\n    };\n  },\n  methods: {\n    goIndex() {\n      this.$router.push({ path: \"/index\" });\n    },\n    goRegister() {\n      this.$router.push({ path: \"/register\" });\n    },\n    submitForm(formName) {\n      const _self = this;\n      const userId = _self.loginInfo.userId;\n      const password = _self.loginInfo.passWord;\n      const url = \"http://localhost:8081/login/loginPassword\";\n      this.$refs[formName].validate((valid) => {\n        if (valid) {\n          _self.$axios\n            .post(url, null, {\n              params: { userId: userId, password: password },\n            })\n            .then((res) => {\n              if (res.status == 200) {\n                if (res.data.code == 0) {\n                  _self.$message.success(\"登录成功\");\n                  setTimeout(() => {\n                    _self.$router.push({ path: \"/index\" });\n                    localStorage.setItem(\"user\", userId);\n                  }, 500);\n                } else {\n                  _self.$message.error(res.data.msg);\n                }\n              }\n            });\n        }\n      });\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.container {\n  width: 1000px;\n  height: 700px;\n  background: #fff;\n  margin: 0 auto;\n  box-shadow: 0 15px 20px rgba(0, 0, 0, 0.11);\n  .banner {\n    width: 1000px;\n    height: 100px;\n    background: #409eff;\n    line-height: 100px;\n    font-size: 20px;\n    color: #fff;\n    text-align: center;\n  }\n  .main {\n    width: 1000px;\n    height: 600px;\n    .phone {\n      width: 50%;\n      height: 250px;\n      margin: 150px auto;\n      position: relative;\n      .txt {\n        font-size: 14px;\n        color: rgb(148, 144, 144);\n        margin-top: 20px;\n      }\n    }\n  }\n}\n.reg {\n  width: 100%;\n}\n.el-form-item {\n  margin-bottom: 32px;\n}\n</style>\n"]}]}