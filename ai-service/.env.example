# ── Service ──────────────────────────────────────────────
APP_NAME=wego-ai-service
APP_VERSION=0.1.0
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO
DEBUG=false

# ── Auth (CHANGE THIS in production!) ────────────────────
SERVICE_KEY=change-me-in-production

# ── Model API (DeepSeek as default) ─────────────────────────
MODEL_API_BASE=https://api.deepseek.com/v1
MODEL_API_KEY=sk-your-deepseek-api-key
MODEL_NAME=deepseek-chat
MODEL_MAX_TOKENS=2048
MODEL_TEMPERATURE=0.7
MODEL_TIMEOUT_SEC=30

# ── Per-endpoint timeouts (seconds) ──────────────────────
TIMEOUT_POLISH=3.0
TIMEOUT_DRAFT=3.0
TIMEOUT_SUMMARY=3.0
TIMEOUT_QUALITY=2.0
TIMEOUT_MODERATION=3.0
TIMEOUT_TOPICS=5.0
TIMEOUT_RECOMMEND=1.5

# ── Retry ────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=2
RETRY_MIN_WAIT_SEC=0.5
RETRY_MAX_WAIT_SEC=2.0

# ── Rate-limit ───────────────────────────────────────────
RATE_LIMIT_PER_MIN=60
